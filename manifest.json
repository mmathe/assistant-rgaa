{
	"manifest_version": 3,
	"name": "Assistant RGAA",
	"description": "Assistant RGAA",
	"version": "1.0.4",
	"icons": {
		"48": "img/icon-48.png",
		"96": "img/icon-96.png"
	},
	"action": {
		"default_icon": "img/icon-96.png",
		"default_title": "Assistant RGAA"
	},
	"permissions": [
		"tabs",
		"storage",
		"scripting"
	],
	"host_permissions": [
		"<all_urls>"
	],
	"background": {
		"service_worker": "dist/background.js"
	},
	"options_ui": {
		"page": "pages/options.html"
	},
	"web_accessible_resources": [
		{
			"resources": [
				"pages/panel.html",
				"pages/devtools.html",
				"data/references/3-2016.json",
				"dist/*.js",
				"dist/*.css",
				"dist/*.map",
				"icons.svg"
			],
			"matches": ["<all_urls>"]
		}
	]
}
